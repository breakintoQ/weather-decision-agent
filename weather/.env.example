# App
APP_ENV=development

# Weather data source
WEATHER_API_BASE=https://api.open-meteo.com/v1
GEOCODING_API_BASE=https://geocoding-api.open-meteo.com/v1
WEATHER_USER_AGENT=weather-agent/1.0
WEATHER_TIMEOUT_SECONDS=30

# Optional China weather alerts via QWeather
QWEATHER_API_HOST=
QWEATHER_API_TOKEN=

# MCP server
WEATHER_MCP_TRANSPORT=stdio
# WEATHER_MCP_SERVER_COMMAND=.venv\Scripts\python.exe
# WEATHER_MCP_SERVER_SCRIPT=weather.py

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
